# ============================================================
# NEURO-NAV — Environment Configuration
# Copy this file to .env and customize for your environment
# ============================================================

# ---- Security ----
# Shared secret between CLI, Daemon, and Extension.
# MUST be identical across all three components.
# Generate a strong token for production: openssl rand -hex 32
NAV_SECRET=neuro_nav_secure_token_2026

# ---- Daemon Server (nav-server) ----
NAV_WS_PORT=9500
NAV_HTTP_PORT=9498
# Use 0.0.0.0 for WSL2→Windows bridge, 127.0.0.1 for local-only
NAV_BIND_HOST=0.0.0.0

# ---- CLI (nav-cli) ----
# Only change these if daemon runs on non-default ports
NAV_SERVER=ws://127.0.0.1:9500
NAV_HTTP=http://127.0.0.1:9498
